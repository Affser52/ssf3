# =========================
# Shared security settings
# =========================
JWT_SECRET=dev-only-change-me-dev-only-change-me-dev-only-change-me
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# =========================
# Kafka / Redis
# =========================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
REDIS_HOST=redis
REDIS_PORT=6379

KAFKA_MESSAGE_TOPIC=message-service
KAFKA_CHAT_TOPIC=chat-service
KAFKA_ENCRYPT_KEYS_TOPIC=encrypt-keys-service
KAFKA_DELETE_ENCRYPT_KEYS_TOPIC=delete-encrypt-keys

# MessageService consumer groups
KAFKA_MESSAGE_GROUP=message-service
KAFKA_CHAT_GROUP=chat-service
KAFKA_ENCRYPT_KEYS_GROUP=encrypt-keys-service
KAFKA_DELETE_ENCRYPT_KEYS_GROUP=delete-encrypt-keys

# Gateway consumer groups (must be different from MessageService)
KAFKA_GATEWAY_MESSAGE_GROUP=gateway-message-service
KAFKA_GATEWAY_CHAT_GROUP=gateway-chat-service
KAFKA_GATEWAY_ENCRYPT_KEYS_GROUP=gateway-encrypt-keys-service

# =========================
# Service URLs
# =========================
USER_SERVICE_URL=http://user-service:8081
MESSAGE_SERVICE_URL=http://message-service:8082
KEY_VAULT_SERVICE_URL=http://key-vault-service:8085

# =========================
# UserService DB
# =========================
USER_DB_URL=jdbc:postgresql://postgres-user:5432/postgres
USER_DB_NAME=postgres
USER_DB_USERNAME=postgres
USER_DB_PASSWORD=postgres

# =========================
# MessageService DB
# =========================
MESSAGE_DB_URL=jdbc:postgresql://postgres-message:5432/postgres
MESSAGE_DB_NAME=postgres
MESSAGE_DB_USERNAME=postgres
MESSAGE_DB_PASSWORD=postgres

# =========================
# KeyVaultService DB
# =========================
KEYVAULT_DB_URL=jdbc:postgresql://postgres-keyvault:5432/postgres
KEYVAULT_DB_NAME=postgres
KEYVAULT_DB_USERNAME=postgres
KEYVAULT_DB_PASSWORD=postgres

# =========================
# FirstVDS S3 storage
# =========================
S3_ENDPOINT=https://s3.firstvds.ru
S3_REGION=default
S3_ACCESS_KEY=replace-with-firstvds-access-key
S3_SECRET_KEY=replace-with-firstvds-secret-key
S3_AVATARS_BUCKET=mescat-avatars
S3_FILES_BUCKET=mescat-files
S3_AVATAR_TEMP_BUCKET=mescat-files
S3_UPLOAD_URL_TTL=3m
S3_DOWNLOAD_URL_TTL=5m
S3_MAX_FILE_SIZE=100MB
S3_CLEANUP_FIXED_DELAY=60000
S3_AVATAR_MAX_FILE_SIZE=5MB
S3_AVATAR_CLEANUP_FIXED_DELAY=60000
